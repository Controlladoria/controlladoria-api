# =============================================================================
# ControlladorIA Configuration
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# AI Provider Configuration
# =============================================================================
# Choose which AI provider to use: openai or anthropic
AI_PROVIDER=openai

# OpenAI API Key
OPENAI_API_KEY=sk-your-key-here

# Or use Anthropic Claude API Key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# AI Model Selection (2026 latest models, cost-optimized)
# OpenAI: gpt-4o-mini ($0.15/$0.60 per 1M tokens) - BEST VALUE ✅
# OpenAI: gpt-4.1-mini ($0.40/$1.60 per 1M tokens) - newer
# OpenAI: gpt-4o ($2.50/$10.00 per 1M tokens) - most powerful
OPENAI_MODEL=gpt-4o-mini

# Anthropic: claude-haiku-4-5 ($1.00/$5.00 per 1M tokens) - latest, fast
# Anthropic: claude-sonnet-4-5 ($3.00/$15.00 per 1M tokens) - most powerful
ANTHROPIC_MODEL=claude-haiku-4-5

# Multi-key AI (comma-separated for round-robin load balancing)
# When set, keys rotate per request to avoid rate limits.
# Falls back to single OPENAI_API_KEY / ANTHROPIC_API_KEY if empty.
# OPENAI_API_KEYS=sk-key1,sk-key2,sk-key3
# ANTHROPIC_API_KEYS=sk-ant-key1,sk-ant-key2

# Auto-failover: if all keys for the primary provider fail, try the secondary
AI_FAILOVER_ENABLED=true

# Mark a key unhealthy after N consecutive errors (auto-recovers after cooldown)
AI_KEY_UNHEALTHY_THRESHOLD=3
AI_KEY_RECOVERY_SECONDS=300

# AI Response Caching (requires Redis - disabled by default)
# Enable when you have Redis running to cache AI responses
# Same document uploaded twice? Instant response, no AI call!
ENABLE_AI_CACHE=false
AI_CACHE_TTL=86400

# AI Retry Configuration (for reliability)
# Automatically retry failed API calls with exponential backoff
AI_MAX_RETRIES=3
AI_RETRY_DELAY=1
AI_TIMEOUT=60

# =============================================================================
# Database Configuration
# =============================================================================
# Local PostgreSQL (Docker): postgresql://controlladoria:controlladoria_dev_2026@localhost:5432/controlladoria
# Production (Railway/Render): postgresql://username:password@endpoint.com:5432/database
# Legacy SQLite: sqlite:///./controlladoria.db
DATABASE_URL=postgresql://controlladoria:controlladoria_dev_2026@localhost:5432/controlladoria

# =============================================================================
# Security & Authentication
# =============================================================================
# JWT Authentication (required)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-random-64-character-hex-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Data Encryption (MFA secrets, sensitive data)
# Optional: If not set, derives from JWT_SECRET_KEY
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Legacy API Authentication (optional)
# If set, clients must provide this key in X-API-Key header
# Generate with: openssl rand -hex 32
API_KEY=your-secret-api-key-here

# =============================================================================
# Stripe Payment Processing
# =============================================================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
# Legacy price ID (treated as basic) - keep for backwards compatibility
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
# Plan-based pricing (create these in Stripe Dashboard)
STRIPE_PRICE_ID_BASIC=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_PRO=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_MAX=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_TRIAL_DAYS=15
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard
STRIPE_CANCEL_URL=http://localhost:3000/pricing

# =============================================================================
# Email Service (Resend)
# =============================================================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=ControlladorIA <noreply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com
SUPPORT_EMAIL=suporte@yourdomain.com
FRONTEND_URL=http://localhost:3000

# =============================================================================
# AWS S3 File Storage
# =============================================================================
# AWS credentials from IAM user
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
S3_BUCKET_NAME=controlladoria-dev-uploads
S3_ENDPOINT_URL=
# Set to true to use S3 instead of local filesystem
USE_S3=false

# AWS SQS (Document Processing Queue — used by Lambda)
SQS_DOCUMENT_QUEUE_URL=

# =============================================================================
# Redis & Caching
# =============================================================================
# Redis connection URL
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# Celery Background Tasks
# =============================================================================
# Usually same as REDIS_URL (use different database numbers)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIME_LIMIT=600

# =============================================================================
# CORS Configuration
# =============================================================================
# Allowed origins for CORS (comma-separated)
# Development: use "*" for all origins
# Production: specify exact domains
CORS_ORIGINS=*
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Trusted Proxy IPs (only trust X-Forwarded-For from these IPs)
# Set to your load balancer/reverse proxy IPs in production
# Empty = never trust X-Forwarded-For (safest default)
# TRUSTED_PROXY_IPS=10.0.0.1,10.0.0.2
TRUSTED_PROXY_IPS=

# =============================================================================
# File Upload Configuration
# =============================================================================
# Maximum file upload size in bytes (default: 30MB)
MAX_UPLOAD_SIZE=31457280

# =============================================================================
# Validation Settings
# =============================================================================
# Enable strict CNPJ validation for Nota Fiscal uploads
# If enabled, Nota Fiscal documents will be rejected if the user's CNPJ is not found as recipient or sender
# This adds a pre-processing AI call and may slow down uploads slightly
ENABLE_CNPJ_VALIDATION=true

# =============================================================================
# SERPRO CNPJ API (Official Receita Federal data)
# =============================================================================
# Sign up: https://loja.serpro.gov.br/consulta-cnpj/product/consultacnpj
# Free trial: 30 days or 3,000 queries
# When configured, SERPRO becomes the primary CNPJ lookup source (BrasilAPI as fallback)
SERPRO_CONSUMER_KEY=
SERPRO_CONSUMER_SECRET=
# Production URL (default). For trial, use: https://gateway.apiserpro.serpro.gov.br/consulta-cnpj-df-trial/v2
SERPRO_API_URL=https://gateway.apiserpro.serpro.gov.br/consulta-cnpj-df/v2

# =============================================================================
# Rate Limiting
# =============================================================================
# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# Upload rate limit (format: "requests/period")
UPLOAD_RATE_LIMIT=60/minute

# Contact form rate limit
CONTACT_RATE_LIMIT=5/hour

# =============================================================================
# Localization
# =============================================================================
# Language (default: pt-BR for Brazilian Portuguese)
LANGUAGE=pt-BR

# =============================================================================
# Logging
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=controlladoria.log

# =============================================================================
# File Cleanup (Scheduled Job)
# =============================================================================
# Enable automatic cleanup of old files
FILE_CLEANUP_ENABLED=true

# File retention period in days (365 = 12 months)
FILE_RETENTION_DAYS=365

# Hour to run cleanup job (0-23, default: 3 AM)
CLEANUP_SCHEDULE_HOUR=3

# Clean up orphaned files (files in uploads but not in database)
CLEANUP_ORPHANED_FILES=true

# =============================================================================
# Document Retry (Nightly retry of failed uploads)
# =============================================================================
# Enable automatic retry of failed documents at 2 AM
DOCUMENT_RETRY_ENABLED=true

# Hour to run retry job (0-23, default: 2 AM)
DOCUMENT_RETRY_HOUR=2

# Max retry attempts before marking as permanently failed
DOCUMENT_MAX_RETRIES=3

# Don't retry documents older than this many days
DOCUMENT_RETRY_MAX_AGE_DAYS=30

# =============================================================================
# Poppler Path (required for PDF processing on Windows)
# =============================================================================
# Download from: https://github.com/oschwartz10612/poppler-windows/releases/
# Extract and point to the bin folder
# POPPLER_PATH=C:/path/to/poppler/Library/bin
